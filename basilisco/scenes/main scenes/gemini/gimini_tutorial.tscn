[node name="RichTextLabel6" type="RichTextLabel" parent="TutorasGemini" unique_id=445418730]
offset_left = 29.0
offset_top = -7.0
offset_right = 291.0
offset_bottom = 191.0
theme_override_fonts/normal_font = ExtResource("2_d2ntx")
theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
text = "Ao escolher 2 cartas e [wave amp=8][color=crimson]Finalizar o turno[/color][/wave], as duas serão somadas.

Caso o resultado seja positivo a soma será [rainbow]acrescentada[/rainbow] a sua pontuação, caso seja negativa o resultado [shake][color=red]diminuirá[/color][/shake] a pontuação do Gemini."
horizontal_alignment = 3

