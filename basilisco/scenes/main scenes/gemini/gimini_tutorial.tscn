[node name="RichTextLabel4" type="RichTextLabel" parent="TutorasGemini" unique_id=1869152480]
offset_left = -583.0
offset_top = -7.0
offset_right = -328.0
offset_bottom = 106.0
theme_override_fonts/normal_font = ExtResource("2_d2ntx")
theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
text = "A cada turno, você receberá 6 cartas. Cartas  [wave amp=8][color=blue]azuis[/color][/wave] representam números positivos e as [wave amp=8][color=red]vermelhas[/color][/wave] os negativos."
autowrap_mode = 2
horizontal_alignment = 3
vertical_alignment = 3

[node name="RichTextLabel5" type="RichTextLabel" parent="TutorasGemini" unique_id=420167911]
offset_left = -288.0
offset_top = -7.0
offset_right = -10.0
offset_bottom = 329.0
theme_override_fonts/normal_font = ExtResource("2_d2ntx")
theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
text = "Por turno você deve escolher 2 cartas, após isso existem 2 ações possiveis [wave amp=8][color=crimson]Finalizar Turno[/color][/wave] e [wave amp=8][color=purple]Fundir[/color][/wave].











Ao [wave amp=8][color=purple]Fundir[/color][/wave] você soma as 2 cartas escolhidas e [rainbow]cria uma nova carta[/rainbow] com base no resultado."
autowrap_mode = 2
horizontal_alignment = 3
vertical_alignment = 3

