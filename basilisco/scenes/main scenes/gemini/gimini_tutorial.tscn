offset_right = 606.0
offset_bottom = 157.0
theme_override_fonts/normal_font = ExtResource("2_d2ntx")
theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
text = "Assim como você, o [rainbow freq=0.1 sat=1.0 val=0.8]Gemini[/rainbow] pode aumentar a pontuação dele e diminuir a sua, mas para ser mais justo (pra você claro) ele sempre irá declarar a próxima ação. 

Seu objetivo é fazer [pulse color=green]100[/pulse] pontos antes dele."
horizontal_alignment = 3

