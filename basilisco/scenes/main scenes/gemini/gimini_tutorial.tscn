[node name="RichTextLabel2" type="RichTextLabel" parent="TutorasGemini" unique_id=779553162]
offset_left = -611.0
offset_top = -240.0
offset_right = 612.0
offset_bottom = -102.0
theme_override_constants/line_separation = 2
theme_override_fonts/normal_font = ExtResource("2_d2ntx")
theme_override_font_sizes/normal_font_size = 23
bbcode_enabled = true
text = "O Gemini entrou na corrida da I.A. como a primeira inteligência nativamente multimodal, integrando-se ao ecossistema [rainbow freq=0.3]Google[/rainbow] para processar texto, imagem e código simultaneamente. Além disso ele se destaca principalmente na área [shake]matemática[/shake] por unir o raciocínio lógico avançado à execução de cálculos em tempo real, permitindo resolver problemas complexos e analisar dados visuais com precisão técnica superior."
horizontal_alignment = 3

[node name="RichTextLabel3" type="RichTextLabel" parent="TutorasGemini" unique_id=1545520194]
